@inject IStudentService StudentService
@using Application.Services.StudentServices
@using Application.DTOs
@page "/students/{id:int}"

<a class="btn btn-primary" href="/students">Back</a>
<div>
    <div class="form-group">
        <label>Id</label>
        <small class="form-control">@student.Id</small>
    </div>
    <div class="form-group">
        <label>Name</label>
        <small class="form-control">@student.FullName</small>
    </div>
    <div class="form-group">
        <label>Sex</label>
        <small class="form-control">@student.Sex</small>
    </div>  
    <div class="form-group">
        <label>Date Of Birth</label>
        <small class="form-control">@student.DateOfBirth</small>
</div>
<div>
    <div class="form-group">
        <label>Phone</label>
        <small class="form-control">@student.Phone</small>
    </div>
    <div class="form-group">
        <label>Email</label>
        <small class="form-control">@student.Email</small>
    </div>
    <div class="form-group">
        <label>Address</label>
        <small class="form-control">@student.Address</small>
    </div>
    <div class="form-group">
        <label>Parent Names</label>
        <small class="form-control">@student.ParentNames</small>
    </div>
    <div class="form-group">
        <label>Parent Phone Number</label>
        <small class="form-control">@student.ParentPhoneNumber</small>
    </div>
    <div class="form-group">
        <label>User Added</label>
        <small class="form-control">@student.UserAdded</small>
    </div>
    <div class="form-group">
        <label>Date Added</label>
        <small class="form-control">@student.DateAdded</small>
    </div>
    <div class="form-group">
        <label>Status</label>
        <small class="form-control">@student.Status</small>
    </div>
</div>
<a class="btn btn-danger" type="submit" href="/Students/Delete/@student.Id" >Delete</a>
<a href="/students/Update/@student.Id"class="btn btn-primary"type="submit" >Update</a>
</div>
@code{
    [Parameter]
    public int Id{get;set;}
    private GetStudentDTO? student;
    protected override async Task  OnParametersSetAsync()
    {
       student =await  StudentService.GetStudentByIdAsync(Id);
    }
}