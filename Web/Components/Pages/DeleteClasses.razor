@page "/Classes/Delete/{id:int}"
@using Application.Services.ClassesServices
@using Application.DTOs
@inject IClassesService ClassesService
@inject NavigationManager navigation
@rendermode InteractiveServer
<h1>Delete Class</h1>

   
    <div>
         <EditForm OnValidSubmit="RemoveClassAsync" Model="classs">
             <p>Are you sure you want to delete this class?</p>
        <div class="form-group">
            <label>Id</label>
            <small class="form-control">@classs?.Id</small>
      
    </div>
   
    

    <button class="btn btn-danger" @onclick="RemoveClassAsync">Delete</button>
    <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
       </EditForm>
</div>
@code{
    [Parameter]
    public int id { get; set; }
    private GetCLassDTO? existingclass;
    public DeleteClassDTO classs=new();
    protected override async Task  OnParametersSetAsync()
    {
        existingclass = await ClassesService.GetClassByIdAsync(id);
        if(existingclass !=null)
        {
         classs.Id=existingclass.Id;
        }
    }

    private async Task RemoveClassAsync()
    {
       
        {
            await ClassesService.DeleteClassAsync(classs);
            navigation.NavigateTo("/Classes");
        }
    }

    private void Cancel()
    {
        navigation.NavigateTo("/Classes");
    }
}