
@rendermode InteractiveServer
@using Infrastructure.Migrations
@using Application.DTOs
@inject NavigationManager Navigation
@using Application.Services.StudentServices
@using MudBlazor.Charts

@inject IStudentService StudentService

<MudDialog>
    <TitleContent>Add Student</TitleContent>
    <DialogContent>
    <EditForm Model="student" OnValidSubmit="SaveStudentAsync">
        <MudGrid>
            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.FullName"
                    Placeholder="FullName"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="FullName">
                </MudTextField>
                 </MudItem>

                <MudItem xs="6">
                <MudSelect
                @bind-Value="@student.Sex"
                T="string"
                    Placeholder=""
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="Sex">
                    <MudSelectItem Value="@("Female")" >Female</MudSelectItem>
                    <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                </MudSelect>
                </MudItem>
            <MudItem xs="6">
                    <MudDatePicker
                        Date="student.DateOfBirth"
                        DateChanged="date => student.DateOfBirth = date ?? default"
                        DateFormat="yyyy-MM-dd"
                        Margin="Margin.Dense"
                        Variant="Variant.Outlined"
                        Label="Date Of Birth"
                        Placeholder="yyyy-MM-dd">
                    </MudDatePicker>
            </MudItem>

            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.Phone"
                    Placeholder="Phone"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="Phone">
                </MudTextField>
            </MudItem>
                
            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.Email"
                    Placeholder="Email"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="Email">
                </MudTextField>
            </MudItem>

            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.Address"
                    Placeholder="Address"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="Address">
                </MudTextField>
            </MudItem>

            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.ParentNames"
                    Placeholder="Parent Names"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="Parent Names">
                </MudTextField>
            </MudItem>
            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.ParentPhoneNumber"
                    Placeholder="Parent Phone Number"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="Parent Phone Number">
                </MudTextField>
            </MudItem>

            <MudItem xs="6">
                <MudTextField
                    @bind-Value="@student.FullName"
                    Placeholder="FullName"
                    Margin="Margin.Dense"
                    Variant="Variant.Outlined"
                    Label="FullName">
                </MudTextField>
            </MudItem>
            <MudItem xs="12">
                <MudButton Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit" Variant="Variant.Filled">SAVE</MudButton>
                </MudItem>
        </MudGrid>
    </EditForm>
    </DialogContent>
</MudDialog>
@code{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private AddStudentDTO student= new ();
    private async Task SaveStudentAsync()
    {
      await StudentService.AddStudentAsync(student);
       MudDialog.Close(DialogResult.Ok(true));
    }
}